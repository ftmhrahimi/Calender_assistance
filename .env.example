# Calendar Assistance — environment variables template
# Copy this file to `.env` and fill in your own values.
# The app reads the token from the DEEPINFRA_API_TOKEN environment variable
# at runtime; it is no longer stored in the source (see CODE_REVIEW.md).

# DeepInfra API token used for LLM inference (https://deepinfra.com/)
DEEPINFRA_API_TOKEN=your-deepinfra-api-token-here
