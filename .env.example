# Calendar Assistance — environment variables template
# Copy this file to `.env` and fill in your own values.
# NOTE: the current release reads the token from the DEEPINFRA_API_TOKEN
# constant in Combinev_org.py; this template documents the intended
# environment-based configuration (see CODE_REVIEW.md).

# DeepInfra API token used for LLM inference (https://deepinfra.com/)
DEEPINFRA_API_TOKEN=your-deepinfra-api-token-here
